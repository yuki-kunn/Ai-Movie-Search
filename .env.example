# Gemini API Key (optional - for AI-powered movie search)
# Get it from: https://ai.google.dev/
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# TMDB API Key (required - for movie data)
# Get it from: https://www.themoviedb.org/settings/api
VITE_TMDB_API_KEY=your_tmdb_api_key_here

# Firebase Configuration (required - for authentication and favorites)
# Get these from: Firebase Console > Project Settings > General > Your apps > SDK setup and configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
